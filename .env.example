PORT=4000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/securebank
JWT_SECRET=change-this-to-a-long-random-string

# For OTP via email (optional - if left blank, OTP will be logged to console)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Comma-separated list of allowed frontend origins in production, e.g.:
# FRONTEND_ORIGINS=https://cherry-bank.vercel.app
FRONTEND_ORIGINS=